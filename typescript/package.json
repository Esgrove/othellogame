{
  "name": "othello_typescript",
  "version": "0.1.0",
  "description": "A simple Othello CLI game implementation",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "build": "bun build ./src/othello.ts --outdir ./dist --target node",
    "othello": "bun src/othello.ts",
    "format": "oxfmt \"**/*.{ts,tsx,js,mjs}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,mjs}\"",
    "fmt": "bun format",
    "lint": "oxlint --fix",
    "lint:check": "oxlint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Esgrove/othellogame.git"
  },
  "author": "Esgrove",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Esgrove/othellogame/issues"
  },
  "homepage": "https://github.com/Esgrove/othellogame#readme",
  "bin": {
    "othello": "./src/othello.ts"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^6.0.3"
  }
}
